# ==============================
# Root .gitignore – libraries, packages, build, logs, secrets
# ==============================

# ----- Node / npm / yarn -----
node_modules/
.npm
.yarn/
.pnp
.pnp.js
.yarn-integrity
# lock files: uncomment to ignore (many teams commit them for reproducible installs)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ----- Next.js / React (ownership-ui-master) -----
.next/
out/
build/
.vercel
*.tsbuildinfo
next-env.d.ts

# ----- Java / Maven (ownership-api-master) -----
target/
!.mvn/wrapper/maven-wrapper.jar
*.jar
*.war
*.class

# ----- Logs -----
*.log
api.log
ui.log
logs/

# ----- Environment and secrets -----
.env
.env.local
.env.*.local
!.env.example

# ----- Fabric / Blockchain (generated or sensitive) -----
# Crypto and generated artifacts (often regenerated by net.sh)
**/crypto-config/
**/channel-artifacts/
**/fabric-ca/
# Wallet identities (contain private keys – do not commit)
ownership-api-master/wallet/*.id
# Chaincode package (built artifact)
**/basic.tar.gz
**/deploy-chaincode/*.tar.gz

# ----- IDE / Editor -----
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.sublime-*

# ----- OS -----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ----- Test / Playwright -----
test-results/
playwright-report/
playwright/.cache
coverage/
.nyc_output/

# ----- Misc -----
*.pyc
__pycache__/
*.swp
*.swo
.cache/
*.tmp
*.temp
.temp/
tmp/
temp/
