# Environment Variables Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
# For local Maven run:
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:55432/asset_holder_db
# For API-in-Docker, use:
# SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/asset_holder_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here
POSTGRES_DB=asset_holder_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=55432
API_HOST_PORT=18081

# Hyperledger Fabric Configuration (use these for stable Assign Asset when running API on host)
FABRIC_CHAINCODE=basic
FABRIC_CHANNEL=channel-org
FABRIC_CRYPTO_PATH=/absolute/path/to/ownership-network-master/channel
FABRIC_PEER_URL=grpcs://127.0.0.1:7051
FABRIC_ORDERER_URL=grpcs://127.0.0.1:7050
FABRIC_DISCOVERY=false
COUCHDB_BASE_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASS=password
NETWORK_CRYPTO_PATH=../ownership-network-master/channel/crypto-config
NETWORK_CONNECTION_PROFILE=../ownership-network-master/connection-profile/connection.yaml

# Optional: wallet directory (default: ownership-api-master/wallet)
# WALLET_PATH=ownership-api-master/wallet
# Optional: Fabric CA cert (API auto-finds under FABRIC_CRYPTO_PATH when running on host)
# FABRIC_CA_PEM_FILE=path/to/.../Admin@org1.ownify.com/tls/ca.crt

# Application Configuration
SERVER_PORT=8081

# --- Assign Asset / orderer unreachable ---
# Use 127.0.0.1 (not localhost) for stable TLS. Start scripts (start-all-projects.sh, start-api-frontend.sh, restart-api-for-blockchain.sh) set these automatically.
# If you run the API from an IDE or mvn spring-boot:run manually, set FABRIC_CRYPTO_PATH (absolute), FABRIC_ORDERER_URL=grpcs://127.0.0.1:7050, FABRIC_PEER_URL=grpcs://127.0.0.1:7051, FABRIC_CHANNEL=channel-org, FABRIC_DISCOVERY=false.
